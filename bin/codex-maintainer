#!/usr/bin/env bash

set -euo pipefail

tool_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'USAGE'
codex-maintainer

Usage:
  codex-maintainer init ios [target] [--force]
  codex-maintainer init web [target] [--force]
  codex-maintainer init backend [target] [--force]
  codex-maintainer init cli [target] [--force]
  codex-maintainer validate [path]
  codex-maintainer doctor [ios|web|backend|cli] [path]
  codex-maintainer policy init [target] [--force]
  codex-maintainer policy show [policy.conf]
  codex-maintainer score <run.md>
  codex-maintainer autopsy --run <run.md> [--diff <patch.diff>] [--tests <test.log>] [--task <task.md>] [--policy <policy.conf>] [--out <dir>]
  codex-maintainer arena run --fixture <fixture-dir> [--out <dir>]
  codex-maintainer arena import --source <fixture-dir> --out <fixture-dir> [--pack-name <name>] [--force]
  codex-maintainer arena sign --fixture <fixture-dir> --out <manifest.json> [--pack-name <name>]
  codex-maintainer arena verify --fixture <fixture-dir> --manifest <manifest.json>
  codex-maintainer review-comment --report <report.json> --out <comment.md> [--mode warn|fail]
  codex-maintainer ci-gate --run <run.md> [--diff <patch.diff>] [--tests <test.log>] [--task <task.md>] [--policy <policy.conf>] [--out <dir>] [--mode warn|fail]
  codex-maintainer ci-summary --gate <gate.json> --out <summary.md>
  codex-maintainer check-run --gate <gate.json> --head-sha <sha> --out <payload.json> [--name <name>]
  codex-maintainer check-run post --payload <payload.json> --repo <owner/repo> --out <response.json> [--api-url <url>] [--token <token>] [--dry-run]
  codex-maintainer sarif --report <report.json> --out <results.sarif>
  codex-maintainer leaderboard build --arena-results <results.json> --out <leaderboard.json>
  codex-maintainer release-manifest --tarball <release.tar.gz> --out <dir> [--version <version>] [--tag <tag>] [--commit <sha>] [--ci-run-url <url>] [--release-url <url>] [--issue-url <url>]
  codex-maintainer release-manifest verify --manifest <release-manifest.json> --tarball <release.tar.gz> [--version <version>] [--tag <tag>]
  codex-maintainer self-audit [--out <dir>]
  codex-maintainer next-goal [--out <file>] [--release <version>] [--title <title>]
  codex-maintainer version
  codex-maintainer help

Commands:
  init        Copy a workflow starter profile into a target repo.
  validate    Validate this workflow bundle or another checkout of it.
  doctor      Check whether a target repo has starter workflow files.
  policy      Initialize or inspect codex-maintainer policy config.
  score       Score a Codex run markdown file using SCORECARD.md categories.
  autopsy     Generate Markdown and JSON evidence reports for an AI coding run.
  arena       Run or import multiple autopsy fixtures.
  review-comment
              Generate a PR-ready review comment and badge from an autopsy report.
  ci-gate     Generate autopsy, review, badge, gate JSON, and optional CI failure.
  ci-summary  Generate GitHub Actions step-summary Markdown from gate JSON.
  check-run   Generate or optionally post GitHub Checks API payloads from gate JSON.
  sarif       Convert an autopsy report JSON file into SARIF 2.1.0.
  leaderboard Build a stable leaderboard JSON file from arena results.
  release-manifest
              Generate release-manifest JSON and proof-ledger Markdown.
  self-audit  Generate toolkit readiness proof.
  next-goal   Generate a slash-goal release objective for the next improvement loop.
  version     Print the toolkit version from VERSION.
USAGE
}

fail() {
  echo "codex-maintainer: $*" >&2
  exit 1
}

copy_file() {
  local source="$1"
  local target="$2"
  local force="$3"

  mkdir -p "$(dirname "$target")"
  if [[ -e "$target" && "$force" != "true" ]]; then
    echo "skip existing: $target"
    return
  fi
  cp "$source" "$target"
  echo "wrote: $target"
}

copy_dir() {
  local source="$1"
  local target="$2"
  local force="$3"

  mkdir -p "$target"
  while IFS= read -r file; do
    local relative="${file#"$source"/}"
    copy_file "$file" "$target/$relative" "$force"
  done < <(find "$source" -type f | sort)
}

copy_profile() {
  local profile="$1"
  local target="$2"
  local force="$3"

  [[ -d "$tool_root/templates/$profile" ]] || fail "unknown init profile: $profile"
  mkdir -p "$target"
  copy_file "$tool_root/templates/$profile/AGENTS.md" "$target/AGENTS.md" "$force"
  copy_file "$tool_root/PLANS.md" "$target/PLANS.md" "$force"
  copy_file "$tool_root/SUBAGENTS.md" "$target/SUBAGENTS.md" "$force"
  copy_file "$tool_root/SCORECARD.md" "$target/SCORECARD.md" "$force"
  copy_dir "$tool_root/.agents/skills" "$target/.agents/skills" "$force"

  echo "initialized $profile Codex workflow starter in $target"
}

cmd_init_profile() {
  local profile="$1"
  shift || true
  local target="."
  local force="false"

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --force)
        force="true"
        ;;
      -*)
        fail "unknown init option: $1"
        ;;
      *)
        target="$1"
        ;;
    esac
    shift
  done

  copy_profile "$profile" "$target" "$force"
}

cmd_validate() {
  local target="${1:-.}"
  "$tool_root/scripts/validate_workflow_bundle.sh" "$target"
}

cmd_doctor() {
  local profile="ios"
  local target="."
  if [[ "$#" -gt 0 ]]; then
    case "$1" in
      ios|web|backend|cli)
        profile="$1"
        shift
        target="${1:-.}"
        [[ "$#" -gt 0 ]] && shift
        ;;
      -*)
        fail "unknown doctor option: $1"
        ;;
      *)
        if [[ "$#" -gt 1 ]]; then
          fail "unknown doctor profile: $1"
        fi
        target="$1"
        shift
        ;;
    esac
  fi
  [[ "$#" -eq 0 ]] || fail "too many doctor arguments"
  local missing=0
  local required=(
    "AGENTS.md"
    "PLANS.md"
    "SUBAGENTS.md"
    "SCORECARD.md"
    ".agents/skills/alarm-testing/SKILL.md"
    ".agents/skills/bug-triage/SKILL.md"
    ".agents/skills/notification-permissions/SKILL.md"
    ".agents/skills/release-checklist/SKILL.md"
    ".agents/skills/ui-polish/SKILL.md"
  )

  [[ -d "$tool_root/templates/$profile" ]] || fail "unknown doctor profile: $profile"

  for file in "${required[@]}"; do
    if [[ -f "$target/$file" ]]; then
      echo "ok: $file"
    else
      echo "missing: $file"
      missing=1
    fi
  done

  if [[ "$missing" -ne 0 ]]; then
    fail "doctor found missing $profile workflow files"
  fi
  echo "doctor passed for $profile"
}

extract_score() {
  local label="$1"
  local file="$2"
  local line
  line="$(grep -iF "$label" "$file" | head -n 1 || true)"
  if [[ "$line" =~ (^|[^0-9])([0-2])([^0-9]|$) ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
  fi
}

verdict_for_total() {
  local total="$1"
  if [[ "$total" -ge 10 ]]; then
    echo "usable maintainer-quality run"
  elif [[ "$total" -ge 7 ]]; then
    echo "probably useful; review weak categories"
  elif [[ "$total" -ge 4 ]]; then
    echo "analysis only; request a narrower repair pass"
  else
    echo "discard as implementation evidence"
  fi
}

cmd_score() {
  local file="${1:-}"
  [[ -n "$file" ]] || fail "score requires a markdown file"
  [[ -f "$file" ]] || fail "score file not found: $file"

  local categories=(
    "Scope control"
    "Owner-file accuracy"
    "Risk awareness"
    "Validation quality"
    "Handoff honesty"
    "Regression awareness"
  )

  local total=0
  local missing=0
  for category in "${categories[@]}"; do
    local score
    score="$(extract_score "$category" "$file" || true)"
    if [[ -z "$score" ]]; then
      echo "$category: missing"
      missing=1
    else
      echo "$category: $score"
      total=$((total + score))
    fi
  done

  [[ "$missing" -eq 0 ]] || fail "score file is missing one or more categories"
  echo "Total score: $total/12"
  echo "Verdict: $(verdict_for_total "$total")"
}

cmd_autopsy() {
  "$tool_root/scripts/autopsy_report.sh" "$@"
}

cmd_policy() {
  "$tool_root/scripts/policy.sh" "$@"
}

cmd_arena() {
  local subcommand="${1:-}"
  [[ "$subcommand" == "run" || "$subcommand" == "import" || "$subcommand" == "sign" || "$subcommand" == "verify" ]] || fail "arena requires subcommand: run, import, sign, or verify"
  shift || true
  case "$subcommand" in
    run)
      "$tool_root/scripts/arena_run.sh" "$@"
      ;;
    import)
      "$tool_root/scripts/arena_import.sh" "$@"
      ;;
    sign)
      "$tool_root/scripts/arena_sign.sh" "$@"
      ;;
    verify)
      "$tool_root/scripts/arena_verify.sh" "$@"
      ;;
  esac
}

cmd_review_comment() {
  "$tool_root/scripts/review_comment.sh" "$@"
}

cmd_ci_gate() {
  "$tool_root/scripts/ci_gate.sh" "$@"
}

cmd_ci_summary() {
  "$tool_root/scripts/ci_summary.sh" "$@"
}

cmd_check_run() {
  "$tool_root/scripts/check_run.sh" "$@"
}

cmd_sarif() {
  "$tool_root/scripts/sarif.sh" "$@"
}

cmd_leaderboard() {
  local subcommand="${1:-}"
  [[ "$subcommand" == "build" ]] || fail "leaderboard requires subcommand: build"
  shift || true
  "$tool_root/scripts/leaderboard_build.sh" "$@"
}

cmd_release_manifest() {
  "$tool_root/scripts/release_manifest.sh" "$@"
}

cmd_self_audit() {
  "$tool_root/scripts/self_audit.sh" "$@"
}

cmd_next_goal() {
  "$tool_root/scripts/next_goal.sh" "$@"
}

cmd_version() {
  local version_file="$tool_root/VERSION"
  [[ -f "$version_file" ]] || fail "VERSION file not found"
  sed -n '1p' "$version_file"
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    init)
      local kind="${1:-}"
      [[ "$kind" == "ios" || "$kind" == "web" || "$kind" == "backend" || "$kind" == "cli" ]] || fail "supported init profiles: ios, web, backend, cli"
      shift || true
      cmd_init_profile "$kind" "$@"
      ;;
    validate)
      cmd_validate "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    policy)
      cmd_policy "$@"
      ;;
    score)
      cmd_score "$@"
      ;;
    autopsy)
      cmd_autopsy "$@"
      ;;
    arena)
      cmd_arena "$@"
      ;;
    review-comment)
      cmd_review_comment "$@"
      ;;
    ci-gate)
      cmd_ci_gate "$@"
      ;;
    ci-summary)
      cmd_ci_summary "$@"
      ;;
    check-run)
      cmd_check_run "$@"
      ;;
    sarif)
      cmd_sarif "$@"
      ;;
    leaderboard)
      cmd_leaderboard "$@"
      ;;
    release-manifest)
      cmd_release_manifest "$@"
      ;;
    self-audit)
      cmd_self_audit "$@"
      ;;
    next-goal)
      cmd_next_goal "$@"
      ;;
    version)
      cmd_version
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      usage
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
