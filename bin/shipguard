cmd_version() {
  local version_file="$tool_root/VERSION"
  [[ -f "$version_file" ]] || fail "VERSION file not found"
  sed -n '1p' "$version_file"
}

main() {
  local command="${1:-help}"
  shift || true

  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    usage
    return 0
  fi

  case "$command" in
    init)
      local kind="${1:-}"
      [[ "$kind" == "ios" || "$kind" == "web" || "$kind" == "backend" || "$kind" == "cli" ]] || fail "supported init profiles: ios, web, backend, cli"
      shift || true
      cmd_init_profile "$kind" "$@"
      ;;
    validate)
      cmd_validate "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    prepare)
      cmd_prepare "$@"
      ;;
    verify)
      cmd_verify "$@"
      ;;
    policy)
      cmd_policy "$@"
      ;;
    score)
      cmd_score "$@"
      ;;
    autopsy)
      cmd_autopsy "$@"
      ;;
    arena)
      cmd_arena "$@"
      ;;
    transcript)
      cmd_transcript "$@"
      ;;
    review-comment)
      cmd_review_comment "$@"
      ;;
    ci-gate)
      cmd_ci_gate "$@"
      ;;
    ci-summary)
      cmd_ci_summary "$@"
      ;;
    check-run)
      cmd_check_run "$@"
      ;;
    sarif)
      cmd_sarif "$@"
      ;;
    docs-check)
      cmd_docs_check "$@"
      ;;
    brand)
      cmd_brand "$@"
      ;;
    value-gauntlet)
      cmd_value_gauntlet "$@"
      ;;
    web)
      cmd_profile web "$@"
      ;;
    backend)
      cmd_profile backend "$@"
      ;;
    cli)
      cmd_profile cli "$@"
      ;;
    ios)
      cmd_ios "$@"
      ;;
    codex)
      cmd_codex "$@"
      ;;
    leaderboard)
      cmd_leaderboard "$@"
      ;;
    release-manifest)
      cmd_release_manifest "$@"
      ;;
    release-index)
      cmd_release_index "$@"
      ;;
    release-replay)
      cmd_release_replay "$@"
      ;;
    release-attest)
      cmd_release_attest "$@"
      ;;
    release-proof)
      cmd_release_proof "$@"
      ;;
    release-consume)
      cmd_release_consume "$@"
      ;;
    release-diff)
      cmd_release_diff "$@"
      ;;
    release-evidence)
      cmd_release_evidence "$@"
      ;;
    self-audit)
      cmd_self_audit "$@"
      ;;
    next-goal)
      cmd_next_goal "$@"
      ;;
    version)
      cmd_version
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      usage
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
