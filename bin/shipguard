cmd_profile() {
  local profile="$1"
  shift || true
  local subcommand="${1:-}"
  [[ "$subcommand" == "audit" || "$subcommand" == "plan" ]] || fail "$profile requires subcommand: audit or plan"
  shift || true
  case "$subcommand" in
    audit)
      run_py "$tool_root/scripts/profile_audit.py" "$profile" "$@"
      ;;
    plan)
      run_py "$tool_root/scripts/profile_fix_plan.py" "$profile" "$@"
      ;;
  esac
}

cmd_ios() {
  local subcommand="${1:-}"
  [[ "$subcommand" == "doctor" || "$subcommand" == "inventory" || "$subcommand" == "preview" || "$subcommand" == "devspace" || "$subcommand" == "devspace-check" || "$subcommand" == "brand" || "$subcommand" == "target-match" || "$subcommand" == "codex-handoff" || "$subcommand" == "plan" || "$subcommand" == "prove" || "$subcommand" == "launchdeck" || "$subcommand" == "performance" || "$subcommand" == "design" || "$subcommand" == "modernize" || "$subcommand" == "app-intelligence" || "$subcommand" == "ai-readiness" || "$subcommand" == "external-audit" || "$subcommand" == "spec-workflow" || "$subcommand" == "report-quality" || "$subcommand" == "redact" || "$subcommand" == "eval" || "$subcommand" == "demo" || "$subcommand" == "goals" ]] || fail "ios requires subcommand: doctor, inventory, preview, devspace, devspace-check, brand, target-match, codex-handoff, plan, prove, launchdeck, performance, design, modernize, app-intelligence, ai-readiness, external-audit, spec-workflow, report-quality, redact, eval, demo, or goals"
  shift || true
  case "$subcommand" in
    doctor)
      run_py "$tool_root/scripts/ios_doctor.py" "$@"
      ;;
    inventory)
      run_py "$tool_root/scripts/ios_inventory.py" "$@"
      ;;
    preview)
      run_py "$tool_root/scripts/ios_preview.py" "$@"
      ;;
    devspace)
      run_py "$tool_root/scripts/shipguard_devspace_mcp.py" --repo-root "$tool_root" "$@"
      ;;
    devspace-check)
      run_py "$tool_root/scripts/ios_devspace_check.py" "$@"
      ;;
    brand)
      run_py "$tool_root/scripts/ios_branding.py" "$@"
      ;;
    target-match)
      run_py "$tool_root/scripts/ios_target_match.py" "$@"
      ;;
    codex-handoff)
      run_py "$tool_root/scripts/ios_codex_handoff.py" "$@"
      ;;
    plan)
      run_py "$tool_root/scripts/ios_plan.py" "$@"
      ;;
    prove)
      run_py "$tool_root/scripts/ios_prove.py" "$@"
      ;;
    launchdeck)
      run_py "$tool_root/scripts/ios_launchdeck.py" "$@"
      ;;
    performance)
      run_py "$tool_root/scripts/ios_performance.py" "$@"
      ;;
    design)
      run_py "$tool_root/scripts/ios_design.py" "$@"
      ;;
    modernize)
      run_py "$tool_root/scripts/ios_modernize.py" "$@"
      ;;
    app-intelligence)
      run_py "$tool_root/scripts/ios_app_intelligence.py" "$@"
      ;;
    ai-readiness)
      run_py "$tool_root/scripts/ios_ai_readiness.py" "$@"
      ;;
    external-audit)
      run_py "$tool_root/scripts/ios_external_audit.py" "$@"
      ;;
    spec-workflow)
      run_py "$tool_root/scripts/ios_spec_workflow.py" "$@"
      ;;
    report-quality)
      run_py "$tool_root/scripts/ios_report_quality.py" "$@"
      ;;
    redact)
      run_py "$tool_root/scripts/ios_redaction.py" "$@"
      ;;
    eval)
      run_py "$tool_root/scripts/ios_shipguard_eval.py" "$@"
      ;;
    demo)
      run_py "$tool_root/scripts/ios_shipguard_demo.py" "$@"
      ;;
    goals)
      run_py "$tool_root/scripts/ios_goal_loop.py" "$@"
      ;;
  esac
}

