  run_sh "$tool_root/scripts/policy.sh" "$@"
}

cmd_arena() {
  local subcommand="${1:-}"
  [[ "$subcommand" == "run" || "$subcommand" == "import" || "$subcommand" == "sign" || "$subcommand" == "verify" || "$subcommand" == "compare" ]] || fail "arena requires subcommand: run, import, sign, verify, or compare"
  shift || true
  case "$subcommand" in
    run)
      run_sh "$tool_root/scripts/arena_run.sh" "$@"
      ;;
    import)
      run_sh "$tool_root/scripts/arena_import.sh" "$@"
      ;;
    sign)
      run_sh "$tool_root/scripts/arena_sign.sh" "$@"
      ;;
    verify)
      run_sh "$tool_root/scripts/arena_verify.sh" "$@"
      ;;
    compare)
      run_sh "$tool_root/scripts/arena_compare.sh" "$@"
      ;;
  esac
}

cmd_transcript() {
  local subcommand="${1:-}"
  [[ "$subcommand" == "redact" || "$subcommand" == "verify" || "$subcommand" == "corpus" ]] || fail "transcript requires subcommand: redact, verify, or corpus"
  shift || true
  case "$subcommand" in
    redact)
      run_sh "$tool_root/scripts/transcript_redact.sh" "$@"
      ;;
    verify)
      run_sh "$tool_root/scripts/transcript_verify.sh" "$@"
      ;;
    corpus)
      run_sh "$tool_root/scripts/transcript_corpus.sh" "$@"
      ;;
  esac
}

