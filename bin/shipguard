#!/usr/bin/env bash

set -euo pipefail

tool_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'USAGE'
shipguard

Usage:
  shipguard init ios [target] [--force]
  shipguard init web [target] [--force]
  shipguard init backend [target] [--force]
  shipguard init cli [target] [--force]
  shipguard validate [path]
  shipguard doctor [ios|web|backend|cli] [path]
  shipguard prepare "task goal" --out <dir> [--path <repo>] [--profile auto|ios|web|backend|cli] [--allowed <glob> ...] [--forbidden <glob> ...] [--validation <cmd> ...] [--claim <text> ...] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard verify --task <shipguard-task.json-or-dir> --out <dir> [--diff <patch.diff>] [--evidence <file> ...] [--claim <text> ...] [--json|--markdown]
  shipguard policy init [target] [--force]
  shipguard policy show [policy.conf]
  shipguard score <run.md>
  shipguard autopsy --run <run.md> [--diff <patch.diff>] [--tests <test.log>] [--task <task.md>] [--policy <policy.conf>] [--out <dir>]
  shipguard arena run --fixture <fixture-dir> [--out <dir>]
  shipguard arena import --source <fixture-dir> --out <fixture-dir> [--pack-name <name>] [--force]
  shipguard arena sign --fixture <fixture-dir> --out <manifest.json> [--pack-name <name>] [--signer <name>] [--signer-url <url>]
  shipguard arena verify --fixture <fixture-dir> --manifest <manifest.json>
  shipguard arena compare --left <results.json> --right <results.json> --out <dir>
  shipguard transcript redact --in <transcript.md> --out <redacted.md> [--report <report.json>] [--private-term <text> ...]
  shipguard transcript verify --in <redacted.md> --out <dir> [--report <redaction-report.json>]
  shipguard transcript corpus --source <dir> --out <dir> [--require-report true|false]
  shipguard review-comment --report <report.json> --out <comment.md> [--mode warn|fail]
  shipguard ci-gate --run <run.md> [--diff <patch.diff>] [--tests <test.log>] [--task <task.md>] [--policy <policy.conf>] [--out <dir>] [--mode warn|fail]
  shipguard ci-summary --gate <gate.json> --out <summary.md>
  shipguard check-run --gate <gate.json> --head-sha <sha> --out <payload.json> [--name <name>]
  shipguard check-run post --payload <payload.json> --repo <owner/repo> --out <response.json> [--api-url <url>] [--token <token>] [--dry-run]
  shipguard sarif --report <report.json> --out <results.sarif>
  shipguard docs-check [path] [--out <dir>]
  shipguard brand [--path <shipguard-repo>] [--out <dir>] [--strict] [--json|--markdown]
  shipguard value-gauntlet [--path <shipguard-repo>] [--out <dir>] [--strict] [--json|--markdown]
  shipguard web audit --path <repo> --out <dir> [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard web plan --report <web-audit-json-or-dir> --out <dir> [--target <repo>] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard backend audit --path <repo> --out <dir> [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard backend plan --report <backend-audit-json-or-dir> --out <dir> [--target <repo>] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard cli audit --path <repo> --out <dir> [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard cli plan --report <cli-audit-json-or-dir> --out <dir> [--target <repo>] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios doctor [--path <ios-project>] [--out <dir>] [--json|--markdown]
  shipguard ios inventory [--path <ios-project>] [--doctor <ios-doctor.json>] [--out <dir>] [--json|--markdown]
  shipguard ios preview --out <dir> [--device booted] [--host 127.0.0.1] [--port 8765]
  shipguard ios devspace [--host 127.0.0.1] [--port 8787] [--preview-url <url>] [--bearer-token-env <env>]
  shipguard ios devspace-check [--path <shipguard-repo>] [--out <dir>] [--preview-out <dir>] [--public-url <url>] [--bearer-token-env <env>] [--shareable] [--strict] [--json|--markdown]
  shipguard ios brand [--path <shipguard-repo>] [--out <dir>] [--strict] [--json|--markdown]
  shipguard ios target-match --handoff <handoff.json> --snapshot <ui.json> [--out <dir>]
  shipguard ios codex-handoff --prompt-file <file>|--prompt <text> --out <dir> [--execute]
  shipguard ios plan --mode <mode> --inventory <ios-inventory.json> --out <file-or-dir>
  shipguard ios prove --plan <ios-plan.json> --out <dir>
  shipguard ios launchdeck --path <repo> --out <dir> [--workflow auto|build-run|debug|preview|performance] [--receipt <file-or-dir> ...] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios performance --path <repo> --out <dir> [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios design --path <repo> --out <dir> [--app-type auto|utility|game|fitness|health|education|kids|creative|commerce|social|finance|saas] [--preview-out <dir>] [--icon-brief] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios modernize --focus swift --path <repo> --out <dir> [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios app-intelligence --path <repo> --out <dir> [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios ai-readiness --path <repo> --out <dir> [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios external-audit --path <shipguard-repo> [--source-path <repo> ...] [--source-url <url> ...] [--out <dir>] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios spec-workflow --path <repo> --feature <text> --out <dir> [--from-report <file-or-dir> ...] [--app-type auto|utility|game|fitness|health|education|kids|creative|commerce|social|finance|saas] [--shipguard-eval] [--shareable] [--json|--markdown]
  shipguard ios report-quality --reports <file-or-dir> [--reports <file-or-dir> ...] [--out <dir>] [--shareable] [--write-fixture-candidates <dir>] [--strict] [--json|--markdown]
  shipguard ios redact --in <file-or-dir> --out <file-or-dir> [--report <report.json>] [--private-term <text> ...]
  shipguard ios eval [--cases <cases.jsonl>] [--out <dir>] [--json|--markdown]
  shipguard ios demo --out <dir> [--fixture <repo>] [--cases <cases.jsonl>]
  shipguard ios goals init|status|next|emit|complete [options]
  shipguard codex status [--cache <dir>] [--strict]
  shipguard leaderboard build --arena-results <results.json> --out <leaderboard.json>
  shipguard release-manifest --tarball <release.tar.gz> --out <dir> [--version <version>] [--tag <tag>] [--commit <sha>] [--ci-run-url <url>] [--release-url <url>] [--issue-url <url>]
  shipguard release-manifest verify --manifest <release-manifest.json> --tarball <release.tar.gz> [--version <version>] [--tag <tag>]
  shipguard release-index build --manifest <release-manifest.json> [--manifest <release-manifest.json> ...] --out <dir> [--title <title>]
  shipguard release-replay verify --manifest <release-manifest.json> --tarball <release.tar.gz> --out <dir> [--index <release-index.json>] [--ledger <proof-ledger.md>]
  shipguard release-attest build --manifest <release-manifest.json> --replay <replay-report.json> --out <dir> [--title <title>]
  shipguard release-proof build --out <dir> --release-url <url> [--version <version>] [--tag <tag>] [--commit <sha>] [--ci-run-url <url>] [--issue-url <url>] [--notes <text>]
  shipguard release-consume verify --dir <downloaded-assets-dir> --out <dir> [--version <version>]
  shipguard release-diff compare --left <release-assets-dir> --right <release-assets-dir> --out <dir>
  shipguard release-evidence site --consume <consumer-proof-dir> --out <dir> [--diff <release-diff-dir>] [--title <title>]
  shipguard release-evidence index --site <evidence-site-dir> [--site <evidence-site-dir> ...] --out <dir> [--title <title>]
  shipguard release-evidence bundle --assets <release-assets-dir> --out <dir> [--version <version>] [--left <previous-release-assets-dir>] [--title <title>] [--index-title <title>]
  shipguard release-evidence verify --dir <evidence-artifact-dir> --out <dir> [--require-diff auto|true|false] [--require-index auto|true|false]
  shipguard release-evidence negative-index --fixture <negative-fixture-dir> --out <dir> [--title <title>]
  shipguard self-audit [--out <dir>]
  shipguard next-goal [--out <file>] [--release <version>] [--title <title>] [--scope <text>] [--completed-scope <text>] [--completion-evidence <text>] [--following-title <title>]
  shipguard version
  shipguard help

Commands:
  init        Copy a workflow starter profile into a target repo.
  validate    Validate this workflow bundle or another checkout of it.
  doctor      Check whether a target repo has starter workflow files.
  prepare     Create a proof-gated task contract before Codex edits.
  verify      Verify a diff, evidence, and claims against a task contract.
  policy      Initialize or inspect shipguard policy config.
  score       Score a Codex run markdown file using SCORECARD.md categories.
  autopsy     Generate Markdown and JSON evidence reports for an AI coding run.
  arena       Run, import, sign, verify, or compare multiple autopsy fixtures.
  transcript  Redact, verify, or index maintainer transcripts before public sharing.
  review-comment
              Generate a PR-ready review comment and badge from an autopsy report.
  ci-gate     Generate autopsy, review, badge, gate JSON, and optional CI failure.
  ci-summary  Generate GitHub Actions step-summary Markdown from gate JSON.
  check-run   Generate or optionally post GitHub Checks API payloads from gate JSON.
  sarif       Convert an autopsy report JSON file into SARIF 2.1.0.
  docs-check  Check Markdown files for broken local links.
  brand       Audit the full ShipGuard branded naming scheme.
  value-gauntlet
              Grade every ShipGuard command, skill, plugin, action, and proof surface for developer value.
  web         Web-focused first-audit and fix-plan reports for starter repos.
  backend     Backend-focused first-audit and fix-plan reports for starter repos.
  cli         CLI-focused first-audit and fix-plan reports for starter repos.
  ios         iOS-focused Codex planning helpers for branded build, debug, permission, preview, performance, and runtime surfaces.
  codex      Check local Codex plugin install status for ShipGuard.
  leaderboard Build a stable leaderboard JSON file from arena results.
  release-manifest
              Generate release-manifest JSON and proof-ledger Markdown.
  release-index
              Build a release proof catalog from release manifests.
  release-replay
              Verify downloaded release assets against manifest, index, and ledger proof.
  release-attest
              Build release attestation JSON, Markdown, and badge proof.
  release-proof
              Build the full release proof bundle in one command.
  release-consume
              Verify downloaded release proof assets and rebuild consumer attestation.
  release-diff
              Compare two release proof asset directories and report what changed.
  release-evidence
              Export or verify release proof evidence sites, indexes, and bundles.
  self-audit  Generate toolkit readiness proof.
  next-goal   Generate slash-plan and slash-goal guidance for the next improvement loop.
  version     Print the toolkit version from VERSION.
USAGE
}

fail() {
  echo "shipguard: $*" >&2
  exit 1
}

run_py() {
  "${PYTHON:-python3}" "$@"
}

run_sh() {
  bash "$@"
}

copy_file() {
  local source="$1"
  local target="$2"
  local force="$3"

  mkdir -p "$(dirname "$target")"
  if [[ -e "$target" && "$force" != "true" ]]; then
    echo "skip existing: $target"
    return
  fi
  cp "$source" "$target"
  echo "wrote: $target"
}

copy_dir() {
  local source="$1"
  local target="$2"
  local force="$3"

  mkdir -p "$target"
  while IFS= read -r file; do
    local relative="${file#"$source"/}"
    copy_file "$file" "$target/$relative" "$force"
  done < <(find "$source" -type f | sort)
}

copy_profile() {
  local profile="$1"
  local target="$2"
  local force="$3"

  [[ -d "$tool_root/templates/$profile" ]] || fail "unknown init profile: $profile"
  mkdir -p "$target"
  copy_file "$tool_root/templates/$profile/AGENTS.md" "$target/AGENTS.md" "$force"
  if [[ -f "$tool_root/templates/$profile/README.md" ]]; then
    copy_file "$tool_root/templates/$profile/README.md" "$target/SHIPGUARD_PROFILE.md" "$force"
  fi
  copy_file "$tool_root/templates/common/PLANS.md" "$target/PLANS.md" "$force"
  copy_file "$tool_root/templates/common/SUBAGENTS.md" "$target/SUBAGENTS.md" "$force"
  copy_file "$tool_root/SCORECARD.md" "$target/SCORECARD.md" "$force"
  copy_dir "$tool_root/.agents/skills" "$target/.agents/skills" "$force"
  copy_dir "$tool_root/scripts/bug-triage" "$target/scripts/bug-triage" "$force"

  echo "initialized $profile Codex workflow starter in $target"
}

cmd_init_profile() {
  local profile="$1"
  shift || true
  local target="."
  local force="false"

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --force)
        force="true"
        ;;
      -*)
        fail "unknown init option: $1"
        ;;
      *)
        target="$1"
        ;;
    esac
    shift
  done

  copy_profile "$profile" "$target" "$force"
}

cmd_validate() {
  local target="${1:-.}"
  run_sh "$tool_root/scripts/validate_workflow_bundle.sh" "$target"
}

cmd_doctor() {
  local profile="ios"
  local target="."
  if [[ "$#" -gt 0 ]]; then
    case "$1" in
      ios|web|backend|cli)
        profile="$1"
        shift
        target="${1:-.}"
        [[ "$#" -gt 0 ]] && shift
        ;;
      -*)
        fail "unknown doctor option: $1"
        ;;
      *)
        if [[ "$#" -gt 1 ]]; then
          fail "unknown doctor profile: $1"
        fi
        target="$1"
        shift
        ;;
    esac
  fi
  [[ "$#" -eq 0 ]] || fail "too many doctor arguments"
  local missing=0
  local required=(
    "AGENTS.md"
    "PLANS.md"
    "SUBAGENTS.md"
    "SCORECARD.md"
    ".agents/skills/alarm-testing/SKILL.md"
    ".agents/skills/bug-triage/SKILL.md"
    ".agents/skills/notification-permissions/SKILL.md"
    ".agents/skills/release-checklist/SKILL.md"
    ".agents/skills/ui-polish/SKILL.md"
    "scripts/bug-triage/prompts.md"
  )

  [[ -d "$tool_root/templates/$profile" ]] || fail "unknown doctor profile: $profile"

  for file in "${required[@]}"; do
    if [[ -f "$target/$file" ]]; then
      echo "ok: $file"
    else
      echo "missing: $file"
      missing=1
    fi
  done

  if [[ "$missing" -ne 0 ]]; then
    fail "doctor found missing $profile workflow files"
  fi
  echo "doctor passed for $profile"
}

extract_score() {
  local label="$1"
  local file="$2"
  local line
  line="$(grep -iF "$label" "$file" | head -n 1 || true)"
  if [[ "$line" =~ (^|[^0-9])([0-2])([^0-9]|$) ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
  fi
}

verdict_for_total() {
  local total="$1"
  if [[ "$total" -ge 10 ]]; then
    echo "usable maintainer-quality run"
  elif [[ "$total" -ge 7 ]]; then
    echo "probably useful; review weak categories"
  elif [[ "$total" -ge 4 ]]; then
    echo "analysis only; request a narrower repair pass"
  else
    echo "discard as implementation evidence"
  fi
}

cmd_score() {
  local file="${1:-}"
  [[ -n "$file" ]] || fail "score requires a markdown file"
  [[ -f "$file" ]] || fail "score file not found: $file"

  local categories=(
    "Scope control"
    "Owner-file accuracy"
    "Risk awareness"
    "Validation quality"
    "Handoff honesty"
    "Regression awareness"
  )

  local total=0
  local missing=0
  for category in "${categories[@]}"; do
    local score
    score="$(extract_score "$category" "$file" || true)"
    if [[ -z "$score" ]]; then
      echo "$category: missing"
      missing=1
    else
      echo "$category: $score"
      total=$((total + score))
    fi
  done

  [[ "$missing" -eq 0 ]] || fail "score file is missing one or more categories"
  echo "Total score: $total/12"
  echo "Verdict: $(verdict_for_total "$total")"
}

cmd_autopsy() {
  run_sh "$tool_root/scripts/autopsy_report.sh" "$@"
}

